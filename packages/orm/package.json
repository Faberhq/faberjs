{
  "name": "@faberjs/orm",
  "version": "0.0.1",
  "description": "FaberJS Eloquent-like ActiveRecord ORM with query builder, relationships, and migrations",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "orm",
    "database",
    "activerecord",
    "migrations"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
